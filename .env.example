# Environment Variables Template
# Copy to .env and fill in values

# Database Configuration
# MariaDB connection string
DATABASE_URL="mysql://root:12345678@db:3306/ubon_health"
DB_ROOT_PASSWORD="12345678"
DB_NAME="ubon_health"
DB_PORT="3306"
APP_PORT="3010"
ADMINER_PORT="8081"
PORT="3010"

# NextAuth.js Configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="ubon-health-insights-dev-secret-2026"
NEXTAUTH_URL="https://coolify.phoubon.in.th"
AUTH_TRUST_HOST="true"

# Application Configuration
NODE_ENV="development"
DEFAULT_FISCAL_YEARS="2569"
BOOTSTRAP_SEED="true"
BOOTSTRAP_ADMIN="true"
ADMIN_EMAIL="admin@ubonlocal.go.th"
ADMIN_NAME="ADMIN Ubon"

# Optional: External Services
# SMTP_EMAIL_HOST="smtp.example.com"
# SMTP_EMAIL_PORT="587"
# SMTP_EMAIL_USER="noreply@example.com"
# SMTP_EMAIL_PASSWORD="password"
# SMTP_EMAIL_FROM="Ubon Health Insights <noreply@example.com>"

# Optional: Logging
# LOG_LEVEL="info"
