// Prisma Schema for Ubon Health Insights
// Database: MariaDB 10.11+
// Generated: 2026-03-21

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"      // MariaDB uses MySQL provider
  url      = env("DATABASE_URL")
}

// ============================================================
// REFERENCE TABLES
// ============================================================

/// Districts reference table (amphoe)
model DimAmphoe {
  id        Int      @id @default(autoincrement()) @db.UnsignedSmallInt
  code      String   @unique @db.VarChar(10)
  nameTh    String    @map("name_th") @db.VarChar(100)
  nameEn    String?   @map("name_en") @db.VarChar(100)
  region    String?   @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  tambons      DimTambon[]
  healthUnits  HealthUnit[]

  @@index([nameTh])
  @@map("dim_amphoe")
}

/// Subdistricts reference table (tambon)
model DimTambon {
  id        Int      @id @default(autoincrement()) @db.UnsignedMediumInt
  amphoeId  Int      @map("amphoe_id") @db.UnsignedSmallInt
  code      String   @unique @db.VarChar(10)
  nameTh    String    @map("name_th") @db.VarChar(100)
  nameEn    String?   @map("name_en") @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  amphoe      DimAmphoe   @relation(fields: [amphoeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  healthUnits HealthUnit[]

  @@index([nameTh])
  @@index([amphoeId])
  @@map("dim_tambon")
}

/// KPI categories (PPFS, TTM, etc.)
model KpiCategory {
  id           Int      @id @default(autoincrement()) @db.UnsignedTinyInt
  code        String   @unique @db.VarChar(20)
  nameTh      String    @map("name_th") @db.VarChar(100)
  nameEn      String?   @map("name_en") @db.VarChar(100)
  description String?   @db.Text
  displayOrder Int      @default(0) @map("display_order") @db.UnsignedTinyInt
  colorCode   String?   @map("color_code") @db.VarChar(7)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  definitions KpiDefinition[]

  @@index([isActive])
  @@index([displayOrder])
  @@map("kpi_categories")
}

/// KPI master definitions
model KpiDefinition {
  id                Int      @id @default(autoincrement()) @db.UnsignedSmallInt
  categoryId        Int      @map("category_id") @db.UnsignedTinyInt
  code              String   @unique @db.VarChar(20)
  nameTh            String    @map("name_th") @db.VarChar(200)
  nameEn            String?   @map("name_en") @db.VarChar(200)
  description       String?   @db.Text
  unit              String    @default("%") @db.VarChar(50)
  targetValue       Decimal?  @map("target_value") @db.Decimal(10, 2)
  targetType        TargetType @default(min) @map("target_type")
  calculationFormula String?  @map("calculation_formula") @db.Text
  dataSource       String?    @map("data_source") @db.VarChar(200)
  reportLink       String?    @map("report_link") @db.VarChar(500)
  displayOrder      Int        @default(0) @map("display_order") @db.UnsignedSmallInt
  isActive          Boolean    @default(true) @map("is_active")
  isDeleted         Boolean    @default(false) @map("is_deleted")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  // Relations
  category  KpiCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  results   KpiResult[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isDeleted])
  @@index([displayOrder])
  @@map("kpi_definitions")
}

/// Fiscal periods time dimension
model FiscalPeriod {
  id          Int      @id @default(autoincrement()) @db.UnsignedSmallInt
  fiscalYear  Int      @map("fiscal_year") @db.UnsignedSmallInt
  quarter     Int      @db.UnsignedTinyInt
  month       Int      @db.UnsignedTinyInt
  monthNameTh String   @map("month_name_th") @db.VarChar(20)
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime  @map("end_date") @db.Date
  isClosed    Boolean   @default(false) @map("is_closed")
  closedAt    DateTime? @map("closed_at")
  closedBy    Int?      @map("closed_by") @db.UnsignedMediumInt

  // Relations
  kpiResults      KpiResult[]
  financeRecords  FinanceRecord[]
  demographics    HealthUnitDemographic[]
  closer          User?        @relation("ClosedBy", fields: [closedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([fiscalYear, quarter, month])
  @@index([fiscalYear])
  @@index([fiscalYear, quarter])
  @@map("fiscal_periods")
}

/// Finance account master for income and expense line items
model FinanceAccount {
  id           Int                @id @default(autoincrement()) @db.UnsignedMediumInt
  type         FinanceAccountType
  nameTh       String             @map("name_th") @db.VarChar(255)
  displayOrder Int                @default(0) @map("display_order") @db.UnsignedSmallInt
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@unique([type, nameTh])
  @@index([type, isActive])
  @@index([displayOrder])
  @@map("finance_accounts")
}

// ============================================================
// CORE ENTITY TABLES
// ============================================================

/// Health service units (รพ.สต.)
model HealthUnit {
  id          Int      @id @default(autoincrement()) @db.UnsignedMediumInt
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(200)
  shortName   String?   @map("short_name") @db.VarChar(100)
  amphoeId    Int       @map("amphoe_id") @db.UnsignedSmallInt
  tambonId    Int?      @map("tambon_id") @db.UnsignedMediumInt
  moo         String?   @db.VarChar(10)
  affiliation String?   @default("อบจ.อุบลราชธานี") @db.VarChar(100)
  email       String?   @db.VarChar(255)
  phone       String?   @db.VarChar(20)
  transferYear Int?     @map("transfer_year") @db.UnsignedSmallInt
  unitSize    String?   @map("unit_size") @db.VarChar(10)
  cupCode     String?   @map("cup_code") @db.VarChar(20)
  cupName     String?   @map("cup_name") @db.VarChar(200)
  localAuthority String? @map("local_authority") @db.VarChar(200)
  province    String?   @db.VarChar(100)
  ucPopulation66 Int?   @map("uc_population_66") @db.UnsignedInt
  ucPopulation67 Int?   @map("uc_population_67") @db.UnsignedInt
  ucPopulation68 Int?   @map("uc_population_68") @db.UnsignedInt
  templeCount Int      @default(0) @map("temple_count") @db.UnsignedTinyInt
  primarySchoolCount Int @default(0) @map("primary_school_count") @db.UnsignedTinyInt
  opportunitySchoolCount Int @default(0) @map("opportunity_school_count") @db.UnsignedTinyInt
  secondarySchoolCount Int @default(0) @map("secondary_school_count") @db.UnsignedTinyInt
  childDevelopmentCenterCount Int @default(0) @map("child_development_center_count") @db.UnsignedTinyInt
  healthStationCount Int @default(0) @map("health_station_count") @db.UnsignedTinyInt
  status      UnitStatus @default(active)
  isDeleted   Boolean   @default(false) @map("is_deleted")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  amphoe      DimAmphoe   @relation(fields: [amphoeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tambon      DimTambon?  @relation(fields: [tambonId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  users       User[]
  kpiResults  KpiResult[]
  financeRecords FinanceRecord[]
  demographics   HealthUnitDemographic[]

  @@index([amphoeId])
  @@index([tambonId])
  @@index([status])
  @@index([isDeleted])
  @@map("health_units")
}

/// User accounts
model User {
  id            Int      @id @default(autoincrement()) @db.UnsignedMediumInt
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  name          String   @db.VarChar(100)
  role          UserRole @default(viewer)
  healthUnitId  Int?     @map("health_unit_id") @db.UnsignedMediumInt
  isActive      Boolean   @default(true) @map("is_active")
  lastLogin     DateTime? @map("last_login")
  loginAttempts Int      @default(0) @map("login_attempts") @db.UnsignedTinyInt
  lockedUntil   DateTime? @map("locked_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  healthUnit            HealthUnit?              @relation(fields: [healthUnitId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  submittedResults      KpiResult[]              @relation("SubmittedBy")
  reviewedResults       KpiResult[]              @relation("ReviewedBy")
  submittedFinances     FinanceRecord[]          @relation("SubmittedFinance")
  recordedDemographics  HealthUnitDemographic[]  @relation("RecordedBy")
  closedPeriods         FiscalPeriod[]           @relation("ClosedBy")
  auditLogs             AuditLog[]

  @@index([role])
  @@index([healthUnitId])
  @@index([isActive])
  @@map("users")
}

// ============================================================
// TRANSACTIONAL TABLES
// ============================================================

/// KPI results fact table
model KpiResult {
  id             Int           @id @default(autoincrement()) @db.UnsignedInt
  kpiId          Int           @map("kpi_id") @db.UnsignedSmallInt
  healthUnitId   Int           @map("health_unit_id") @db.UnsignedMediumInt
  fiscalPeriodId Int           @map("fiscal_period_id") @db.UnsignedSmallInt
  targetValue    Decimal       @map("target_value") @db.Decimal(15, 2)
  actualValue    Decimal       @map("actual_value") @db.Decimal(15, 2)
  percentage     Decimal       @db.Decimal(5, 2)
  notes          String?       @db.Text
  evidenceUrl    String?       @map("evidence_url") @db.VarChar(500)
  submittedBy    Int?          @map("submitted_by") @db.UnsignedMediumInt
  submittedAt    DateTime?     @map("submitted_at")
  reviewedBy     Int?          @map("reviewed_by") @db.UnsignedMediumInt
  reviewedAt     DateTime?     @map("reviewed_at")
  reviewStatus   ReviewStatus  @default(draft) @map("review_status")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Relations
  kpi           KpiDefinition @relation(fields: [kpiId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  healthUnit    HealthUnit    @relation(fields: [healthUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  fiscalPeriod  FiscalPeriod  @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  submitter     User?         @relation("SubmittedBy", fields: [submittedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)
  reviewer      User?         @relation("ReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([kpiId, healthUnitId, fiscalPeriodId])
  @@index([kpiId])
  @@index([healthUnitId])
  @@index([fiscalPeriodId])
  @@index([reviewStatus])
  @@index([percentage])
  @@index([healthUnitId, fiscalPeriodId])
  @@map("kpi_results")
}

/// Finance records
model FinanceRecord {
  id               Int      @id @default(autoincrement()) @db.UnsignedInt
  healthUnitId     Int      @map("health_unit_id") @db.UnsignedMediumInt
  fiscalPeriodId   Int      @map("fiscal_period_id") @db.UnsignedSmallInt
  income           Decimal  @default(0) @db.Decimal(15, 2)
  expense          Decimal  @default(0) @db.Decimal(15, 2)
  balance          Decimal  @default(0) @db.Decimal(15, 2)
  incomeBreakdown  Json?    @map("income_breakdown")
  expenseBreakdown Json?    @map("expense_breakdown")
  notes            String?  @db.Text
  recorder         String?  @db.VarChar(100)
  submittedBy      Int?     @map("submitted_by") @db.UnsignedMediumInt
  submittedAt      DateTime? @map("submitted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  healthUnit   HealthUnit    @relation(fields: [healthUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  fiscalPeriod FiscalPeriod  @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  submitter    User?         @relation("SubmittedFinance", fields: [submittedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([healthUnitId, fiscalPeriodId])
  @@index([healthUnitId])
  @@index([fiscalPeriodId])
  @@index([healthUnitId, fiscalPeriodId])
  @@map("finance_records")
}

/// Health unit demographics (time-series)
model HealthUnitDemographic {
  id               Int       @id @default(autoincrement()) @db.UnsignedInt
  healthUnitId     Int       @map("health_unit_id") @db.UnsignedMediumInt
  fiscalPeriodId   Int       @map("fiscal_period_id") @db.UnsignedSmallInt
  male             Int?      @db.UnsignedInt
  female           Int?      @db.UnsignedInt
  totalPopulation  Int?      @map("total_population") @db.UnsignedInt
  elderlyPopulation Int?     @map("elderly_population") @db.UnsignedInt
  villages         Int?      @db.UnsignedInt
  households      Int?      @db.UnsignedInt
  healthVolunteers Int?     @map("health_volunteers") @db.UnsignedInt
  recordedBy       Int?      @map("recorded_by") @db.UnsignedMediumInt
  recordedAt       DateTime  @default(now()) @map("recorded_at")

  // Relations
  healthUnit   HealthUnit   @relation(fields: [healthUnitId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  recorder     User?        @relation("RecordedBy", fields: [recordedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([healthUnitId, fiscalPeriodId])
  @@index([healthUnitId])
  @@index([fiscalPeriodId])
  @@map("health_unit_demographics")
}

// ============================================================
// AUDIT TABLE
// ============================================================

/// Audit logs for compliance
model AuditLog {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  tableName   String   @map("table_name") @db.VarChar(50)
  recordId    String   @map("record_id") @db.VarChar(50)
  action      AuditAction
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  changedBy   Int?     @map("changed_by") @db.UnsignedMediumInt
  changedAt   DateTime  @default(now()) @map("changed_at")
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent") @db.VarChar(500)

  // Relations
  user User? @relation(fields: [changedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([tableName])
  @@index([tableName, recordId])
  @@index([changedBy])
  @@index([changedAt])
  @@index([action])
  @@map("audit_logs")
}

// ============================================================
// ENUMS
// ============================================================

enum TargetType {
  min   @map("min")
  max   @map("max")
  exact @map("exact")
}

enum UnitStatus {
  active   @map("active")
  inactive @map("inactive")
}

enum UserRole {
  admin   @map("admin")
  manager @map("manager")
  staff   @map("staff")
  viewer  @map("viewer")
}

enum FinanceAccountType {
  income  @map("income")
  expense @map("expense")
}

enum ReviewStatus {
  draft     @map("draft")
  submitted @map("submitted")
  approved  @map("approved")
  rejected  @map("rejected")
}

enum AuditAction {
  INSERT @map("INSERT")
  UPDATE @map("UPDATE")
  DELETE @map("DELETE")
}
